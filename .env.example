# ── Required ────────────────────────────────────────────────────────────────
THREADS_APP_ID=your_meta_app_id
THREADS_APP_SECRET=your_meta_app_secret
THREADS_USER_ID=
OPENROUTER_API_KEY=your_openrouter_api_key

# ── First-run only (SQLite takes over after auth) ────────────────────────────
# THREADS_ACCESS_TOKEN=your_initial_long_lived_token

# ── Optional ─────────────────────────────────────────────────────────────────
THREADS_REDIRECT_URI=https://localhost/callback
OPENROUTER_MODEL=anthropic/claude-opus-4-6
SEARCH_QUERIES=viral,tech,AI,trending
MIN_SOURCE_POSTS=10
MIN_SOURCE_QUERIES=3
MAX_SOURCE_POSTS_PER_QUERY=4
POST_TIMES=09:00,17:00
TIMEZONE=Asia/Jakarta
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
DRY_RUN=false
DB_PATH=data/state.db
LOG_LEVEL=info
